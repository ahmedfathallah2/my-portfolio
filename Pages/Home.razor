@page "/"

<PageTitle>Ahmed Fathallah | Portfolio</PageTitle>

<section class="hero">
    <div class="hero-text">
        <span class="tag">Available for Opportunities</span>
        <h1>Ahmed Fathallah</h1>
        <h3>.NET & Blazor Developer</h3>
        <p>
            I build modern, responsive, and user-friendly web applications
            using Blazor, ASP.NET Core, C#, and SQL Server.
        </p>

        <div class="hero-buttons">
            <a class="btn-primary-custom" href="#projects">View Projects</a>
            <a class="btn-outline-custom" href="#contact">Contact Me</a>
        </div>
    </div>
</section>

<section id="about" class="section">
    <div class="section-header">
        <span class="section-label">About Me</span>
        <h2>Creating clean solutions with modern .NET technologies</h2>
    </div>

    <p class="section-text">
        I am a passionate developer focused on building professional web applications
        with clean UI, solid backend logic, and responsive design. I enjoy turning ideas
        into real products using Blazor, ASP.NET Core, and C#.
    </p>
</section>

<section id="skills" class="section">
    <div class="section-header">
        <span class="section-label">Skills</span>
        <h2>Technologies I work with</h2>
    </div>

    <div class="skills-grid">
        <div class="skill-card">
            <h4>Frontend</h4>
            <p>Blazor, HTML, CSS, Bootstrap, Responsive Design</p>
        </div>

        <div class="skill-card">
            <h4>Backend</h4>
            <p>ASP.NET Core, C#, REST APIs, Entity Framework Core</p>
        </div>

        <div class="skill-card">
            <h4>Database</h4>
            <p>SQL Server, LINQ, Database Design</p>
        </div>

        <div class="skill-card">
            <h4>Tools</h4>
            <p>Visual Studio, Git, GitHub, Postman</p>
        </div>
    </div>
</section>

<section id="projects" class="section">
    <div class="section-header">
        <span class="section-label">Projects</span>
        <h2>Some of my recent work</h2>
    </div>

    <div class="projects-grid">
        <div class="project-card">
            <h3>Portfolio Website</h3>
            <p>
                A personal portfolio built with Blazor to showcase my skills,
                projects, and contact information in a professional way.
            </p>
            <div class="project-tech">
                <span>Blazor</span>
                <span>C#</span>
                <span>CSS</span>
            </div>
        </div>

        <div class="project-card">
            <h3>Student Management System</h3>
            <p>
                A web application for managing students, courses, and records
                with a clean dashboard and structured database design.
            </p>
            <div class="project-tech">
                <span>ASP.NET Core</span>
                <span>SQL Server</span>
                <span>Entity Framework</span>
            </div>
        </div>

        <div class="project-card">
            <h3>E-Commerce Web App</h3>
            <p>
                A modern online store project with product listing, categories,
                shopping cart logic, and responsive user interface.
            </p>
            <div class="project-tech">
                <span>Blazor</span>
                <span>SQL Server</span>
                <span>Bootstrap</span>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="section contact-section">
    <div class="section-header">
        <span class="section-label">Contact</span>
        <h2>Let’s work together</h2>
    </div>

    <p class="section-text">
        I’m open to internships, freelance projects, and junior developer opportunities.
    </p>

    <div class="contact-box">
        <p><strong>Email:</strong> ahmed@example.com</p>
        <p><strong>GitHub:</strong> github.com/ahmedfathallah2</p>
        <p><strong>LinkedIn:</strong> linkedin.com/in/your-linkedin</p>
    </div>
</section>